<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DemoApp_AvRichtextBox.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:avrtb="using:AvRichTextBox"
		xmlns:cc="using:CustomControls"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="800" Height="800" Width="1000" MinWidth="500" MinHeight="200"
        x:Class="DemoApp_AvRichtextBox.Views.MainWindow" WindowStartupLocation="CenterScreen" x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico" Title="{Binding CurrentOpenFileNameExt}">


	<DockPanel>

		<!-- Formatting controls panel -->
		<DockPanel DockPanel.Dock="Top"  >

			<DockPanel DockPanel.Dock="Left" Width="150" LastChildFill="False" >
				<Menu DockPanel.Dock="Top" BorderBrush="Gray" BorderThickness="1">

					<MenuItem Header="File">
						<MenuItem Header="New document" Click="CreateNewDocumentMenuItem_Click"/>
						<Separator/>
						<MenuItem Header="Load XamlPackage" Click="LoadXamlPackageMenuItem_Click"/>
						<MenuItem Header="Save XamlPackage" Click="SaveXamlPackageMenuItem_Click"/>
						<Separator/>
						<MenuItem Header="Load Rtf file" Click="LoadRtfFileMenuItem_Click"/>
						<MenuItem Header="Save Rtf file" Click="SaveRtfFileMenuItem_Click"/>
						<Separator/>
						<MenuItem Header="Load Word file" Click="LoadWordFileMenuItem_Click"/>
						<MenuItem Header="Save Word file" Click="SaveWordFileMenuItem_Click"/>
						<Separator/>
						<MenuItem Header="Load Html file" Click="LoadHtmlFileMenuItem_Click"/>
						<MenuItem Header="Save Html file" Click="SaveHtmlFileMenuItem_Click"/>
						<Separator Height="2"/>
						<MenuItem Header="Open test files folder" Click="OpenTestFilesFolderMenuItem_Click"/>
					</MenuItem>

				</Menu>


				<DockPanel Margin="2, 10, 2, 5" DockPanel.Dock="Top">
					<Button x:Name="FindBut" Content="Find" DockPanel.Dock="Top" Click="FindButton_Click" />

					<TextBox x:Name="FindTB" Text="" GotFocus="FindTextBox_GotFocus" Background="LightGray" KeyDown="FindTextBox_KeyDown" FontSize="16" Margin="2, 4" Focusable="True">
						<TextBox.Styles>
							<Style Selector="TextBox:pointerover /template/ Border">
								<Setter Property="Background" Value="{TemplateBinding Background}" />
							</Style>
						</TextBox.Styles>
					</TextBox>
				</DockPanel>

			</DockPanel>

			<Border BorderThickness="1.5" BorderBrush="DarkBlue" Margin="15, 1, 5, 1" Padding="2">

				<StackPanel  x:Name="TopStackPanel"  Background="LightGray" Spacing="8" HorizontalAlignment="Stretch" Orientation="Horizontal">

					<Border BorderBrush="Brown" BorderThickness="3" Padding="5">
						<DockPanel LastChildFill="False">


							<DockPanel DockPanel.Dock="Top">
								<TextBlock DockPanel.Dock="Top" HorizontalAlignment="Center" Text="Run"/>
								<TextBlock Text="Font:" Margin="3,0" VerticalAlignment="Center"/>
								<ComboBox x:Name="FontsCB" Height="35" Width="170" FontSize="16" DropDownClosed="FontsComboBox_DropDownClosed" Focusable="False" />
							</DockPanel>

							<DockPanel DockPanel.Dock="Top" Margin="3, 5">
								
								<DockPanel DockPanel.Dock="Left" Width="50" HorizontalAlignment="Right" Margin="1" LastChildFill="False">
									<cc:NumericSpinner x:Name="FontSizeNS" Width="52" Margin="1" MinValue="5" MaxValue="50"  Value="50" Height="30" FontSize="16"
										   UserValueChanged="FontSizeNS_UserValueChanged" DockPanel.Dock="Bottom" />
									<TextBlock Text="Font size:" FontSize="10" DockPanel.Dock="Bottom" Margin="2,0" VerticalAlignment="Center"/>
									
								</DockPanel>

								<DockPanel DockPanel.Dock="Top">
									<DockPanel DockPanel.Dock="Top" Margin="4">
										<ColorPicker x:Name="FontColorCP" Color="Black" ColorChanged="FontCP_ColorChanged" DockPanel.Dock="Right" Width="70"  Height="25" Background="White"/>
										<TextBlock Text="Font color:" HorizontalAlignment="Right" Margin="3,0" VerticalAlignment="Center"/>
									</DockPanel>

									<DockPanel Margin="4" DockPanel.Dock="Top">
										<ColorPicker Color="White" x:Name="HighlightCP"  ColorChanged="HighlightCP_ColorChanged"  DockPanel.Dock="Right" Width="70"  Height="25" />
										<TextBlock Text="Highlight:" HorizontalAlignment="Right" Margin="3,0" VerticalAlignment="Center" />

									</DockPanel>

								</DockPanel>

							</DockPanel>

							<Border BorderBrush="Black" BorderThickness="1" >
								<DockPanel>
									<CheckBox x:Name="StrikeCB" Margin="3, 0" Padding="1" DockPanel.Dock="Left" Content="Strike" />
									<CheckBox x:Name="UnderCB"  Margin="3, 0"  Padding="1" DockPanel.Dock="Left" Content="Underline"  />
									<CheckBox x:Name="OverCB"  Margin="3, 0"  Padding="1" Content="Overline"  />
								</DockPanel>
							</Border>
						</DockPanel>

					</Border>

					<Border BorderBrush="Brown" BorderThickness="3" Padding="5">
						<DockPanel>
							<TextBlock Text="Paragraph" DockPanel.Dock="Top" HorizontalAlignment="Center"/>
							<DockPanel>
								<DockPanel DockPanel.Dock="Top">
									
									<DockPanel DockPanel.Dock="Left" LastChildFill="False" >
										<TextBlock Text="Line height"  TextWrapping="Wrap" DockPanel.Dock="Top"/>
										<cc:NumericSpinner x:Name="LineHeightNS" Width="55" Margin="3" MinValue="0" MaxValue="400" Value="0" Height="30" DockPanel.Dock="Top" FontSize="16"
														 UserValueChanged="LineHeightNS_UserValueChanged" />
									</DockPanel>

									<DockPanel Margin="2">
										<DockPanel DockPanel.Dock="Top">
											<ComboBox x:Name="JustificationCB" DropDownClosed="JustificationComboBox_DropDownClosed" Margin="3" Width="95" MinHeight="15" Height="27" DockPanel.Dock="Right" FontSize="12" Focusable="False">
												<ComboBox.Styles>
													<Style Selector="ComboBoxItem">
														<Setter Property="Padding" Value="5, 0"/>
														<Setter Property="Height" Value="20"/>
														<Setter Property="MinHeight" Value="12"/>
														<Setter Property="Foreground" Value="Black"/>
													</Style>
												</ComboBox.Styles>
												<ComboBoxItem Content="Left"/>
												<ComboBoxItem Content="Center"/>
												<ComboBoxItem Content="Right"/>
												<ComboBoxItem Content="Justified" />
											</ComboBox>
											<TextBlock  Text="Just." VerticalAlignment="Center" HorizontalAlignment="Right"/>
										</DockPanel>
										<ColorPicker  x:Name="ParBackgroundCP" ColorChanged="ParBackground_ColorChanged" Color="Transparent" DockPanel.Dock="Right" Width="70"  Height="25" Background="White" VerticalAlignment="Center"  Focusable="False"/>
										<TextBlock Text="Back-ground:" Width="52"  TextWrapping="Wrap"  HorizontalAlignment="Right" Margin="3,0" VerticalAlignment="Center"/>
									</DockPanel>

								</DockPanel>
								
								<DockPanel>
									<TextBlock DockPanel.Dock="Top" Text="Border" VerticalAlignment="Center" Margin="0, -10, 0, 0"  TextWrapping="Wrap" HorizontalAlignment="Right"/>
									<cc:NumericSpinner x:Name="ParagraphBorderNS" Width="42" Margin="3" MinValue="0" MaxValue="20" Value="0" Height="30" DockPanel.Dock="Right" 
													   FontSize="16" UserValueChanged="ParagraphBorderNS_UserValueChanged"/>
								</DockPanel>

								<DockPanel DockPanel.Dock="Top" Margin="4">
									<ColorPicker Color="Black" x:Name="ParBorderCP" ColorChanged="ParBorder_ColorChanged" DockPanel.Dock="Right" Width="70"  Height="25" Background="White"
										Focusable="False" />
									<TextBlock Text="Border color:" Width="50" TextAlignment="Right" TextWrapping="Wrap" HorizontalAlignment="Right" Margin="3,0" VerticalAlignment="Center"/>
								</DockPanel>

							</DockPanel>
						</DockPanel>
					</Border>

					<Border BorderBrush="Brown" BorderThickness="3" Padding="5">
						<DockPanel DockPanel.Dock="Top" Margin="0" >
							<TextBlock Text="FlowDoc" HorizontalAlignment="Center" DockPanel.Dock="Top"  />
							<TextBlock Text="Page padding" HorizontalAlignment="Center" DockPanel.Dock="Top" VerticalAlignment="Top" Margin="0, 10, 0, 5"  />

							<DockPanel>
							<DockPanel DockPanel.Dock="Top">
								<TextBlock Text="L" VerticalAlignment="Center" DockPanel.Dock="Left"/>
								<cc:NumericSpinner x:Name="PagePaddingNSL" Width="50" MinValue="0" MaxValue="150" Margin="3" Value="50" Height="28" FontSize="16"
												   ValueChanged="PagePaddingNSL_ValueChanged" />
							</DockPanel>

							<DockPanel DockPanel.Dock="Top">
								<TextBlock Text="T" VerticalAlignment="Center" DockPanel.Dock="Left"/>
								<cc:NumericSpinner x:Name="PagePaddingNST" Width="50" MinValue="0" MaxValue="150" Margin="3" Value="50" Height="28" FontSize="16"
												   ValueChanged="PagePaddingNST_ValueChanged" />
							</DockPanel>

							</DockPanel>
							
							<DockPanel DockPanel.Dock="Top">
								<TextBlock Text="R" VerticalAlignment="Center" DockPanel.Dock="Left"/>
								<cc:NumericSpinner x:Name="PagePaddingNSR" Width="50" MinValue="0" MaxValue="150" Margin="3" Value="50" Height="28" FontSize="16"
												   ValueChanged="PagePaddingNSR_ValueChanged" />
							</DockPanel>

							<DockPanel DockPanel.Dock="Top">
								<TextBlock Text="B" VerticalAlignment="Center" DockPanel.Dock="Left"/>
								<cc:NumericSpinner x:Name="PagePaddingNSB" Width="50" MinValue="0" MaxValue="150" Margin="3" Value="50" Height="28" FontSize="16"
												   ValueChanged="PagePaddingNSB_ValueChanged" />
							</DockPanel>


						</DockPanel>
					</Border>
					<Border BorderBrush="Brown" BorderThickness="3" Padding="5">
						<DockPanel LastChildFill="False" >
							<TextBlock Text="RichTextBox" DockPanel.Dock="Top"/>
							<DockPanel LastChildFill="False" DockPanel.Dock="Top" Margin="0, 10, 0, 0">
								<TextBlock Text="Zoom" DockPanel.Dock="Top"/>
								<cc:NumericSpinner Width="50" MinValue="0.3" Step="0.1" MaxValue="12" Margin="1" Value="1" Height="28" FontSize="16"
												   UserValueChanged="RTBZoomNS_UserValueChanged"/>
							</DockPanel>
							<CheckBox Content="ReadOnly" DockPanel.Dock="Top" IsCheckedChanged="CheckBox_IsCheckedChanged" Focusable="False" />
							
						</DockPanel>
					</Border>
				</StackPanel>

			</Border>

		</DockPanel>

		<Grid >
	
		<avrtb:RichTextBox Grid.Row="0" x:Name="MainRTB" Zoom="1" IsReadOnly="False" LineBreakOnShiftEnter="True" ShowDebuggerPanelInDebugMode="True"  DisableUserCopy="False" 
					 CaretBrush="DarkBlue" CtrlKeyOpensHyperlink="True"/>

			<!-- Test a second RTB in tandem-->
			<!--<avrtb:RichTextBox Grid.Row="1" x:Name="MainRTB2"  IsReadOnly="False" LineBreakOnShiftEnter="True" ShowDebuggerPanelInDebugMode="True"  DisableUserCopy="False" SelectionBrush="LightGreen" />-->
			
		</Grid>
		<!--RTB with direct content -->
		<!--<avrtb:RichTextBox x:Name="MainRTB"  IsReadOnly="False" LineBreakOnShiftEnter="True" ShowDebuggerPanelInDebugMode="True" DisableUserCopy="False"  >
			
			<avrtb:RichTextBox.FlowDocument>
				<avrtb:FlowDocument >
					<avrtb:FlowDocument.Blocks>
						<avrtb:Paragraph>
							<avrtb:Paragraph.Inlines>
								<avrtb:EditableRun Text="Test line 1"/>
								<avrtb:EditableLineBreak/>
							</avrtb:Paragraph.Inlines>
						</avrtb:Paragraph>
	
						<avrtb:Paragraph>
							<avrtb:Paragraph.Inlines>
								<avrtb:EditableInlineUIContainer>
									<Image Width="100" Height="60" Source="avares://DemoApp_AvRichTextBox/Assets/avalonia-logo.ico"/>
								</avrtb:EditableInlineUIContainer>
							</avrtb:Paragraph.Inlines>
						</avrtb:Paragraph>
	
						<avrtb:Paragraph>
							<avrtb:Paragraph.Inlines>
								<avrtb:EditableRun Text="Test line 2"/>
							</avrtb:Paragraph.Inlines>
						</avrtb:Paragraph>

						<avrtb:Paragraph/>

					--><!--	<avrtb:Table ColDefs="100, 150, 100, 100" Height="300" RowDefs="100, 100, 100" BorderThickness="3"/>--><!--

					--><!--	<avrtb:Table BorderThickness="7" ColDefs="100, 150, 100, 100" RowDefs="100, 100, 100" >
							<avrtb:Table.Cells>
								<avrtb:Cell RowNo="0" ColNo="0" BorderBrush="Red" BorderThickness="1" >
									<avrtb:Cell.CellContent>
										<avrtb:Paragraph>
											<avrtb:Paragraph.Inlines>
												<avrtb:EditableRun Text="Cell text"/>
											</avrtb:Paragraph.Inlines>
										</avrtb:Paragraph>
									</avrtb:Cell.CellContent>
									</avrtb:Cell>
								<avrtb:Cell RowNo="0" ColNo="2" BorderBrush="Red" BorderThickness="5"/>
								<avrtb:Cell RowNo="2" ColNo="1" BorderBrush="Green" BorderThickness="2"/>
								<avrtb:Cell RowNo="2" ColNo="3" BorderBrush="Red" BorderThickness="2"/>
							</avrtb:Table.Cells>
						</avrtb:Table>
						--> <!--

					</avrtb:FlowDocument.Blocks>
				</avrtb:FlowDocument>
			</avrtb:RichTextBox.FlowDocument>

		</avrtb:RichTextBox>-->

	</DockPanel>



</Window>
